# AUNIX backend environment
# Copy this to .env for local dev and set values.

# Postgres connection string. SQLAlchemy format.
# Local dev example:
DATABASE_URL=postgresql+psycopg2://localhost:5432/aunix

# Long random secret used to sign JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-me

# Hours a login JWT remains valid.
JWT_EXPIRY_HOURS=24

# The public URL of THIS API. Baked into agent packages so scanners know
# where to phone home. Must include scheme and the /api prefix.
# Local dev example:
PUBLIC_API_URL=http://127.0.0.1:8000/api

# Comma-separated origins allowed to call the API from a browser.
# Add the URL where your static frontend is served.
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
